{
  "folders": [
    {
      "path": "."
    },
    {
      "path": "../core"
    }
  ],
  "settings": {
    "python.defaultInterpreterPath": "/home/vscode/.local/ha-venv/bin/python",
    "python.analysis.exclude": [
      "**/node_modules",
      "**/__pycache__",
      "**/.*",
      "**/.mypy_cache/**",
      "**/.pytest_cache/**",
      "**/.ruff_cache/**",
      "**/.tmp/**",
      "**/site-packages/**"
    ],
    "search.exclude": {
      "**/node_modules": true,
      "**/__pycache__": true,
      "**/.*": true,
      "**/.mypy_cache": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/.tmp": true,
      "**/site-packages": true,
      "/home/vscode/.local/ha-venv": true
    },
    "files.exclude": {
      "**/node_modules": true,
      "**/__pycache__": true,
      "**/.mypy_cache": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/site-packages": true,
      "/home/vscode/.local/ha-venv": true
    },
    "pylint.args": [
      "--ignore-paths=^\\.mypy_cache/.*$,^\\.pytest_cache/.*$,^\\.ruff_cache/.*$,^\\.tmp/.*$,^.*/site-packages/.*$,^/home/vscode/\\.local/ha-venv/.*$,^/workspaces/core/.*$"
    ],
    "pylint.ignorePatterns": [
      "**/.tmp/**/*.py",
      "**/site-packages/**/*.py",
      "/home/vscode/.local/ha-venv/**/*.py",
      "/workspaces/core/**/*.py"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Auto-Link Control D Manager",
        "type": "shell",
        "command": "mkdir -p /workspaces/core/config/custom_components && ln -snf /workspaces/controld-manager-ha/custom_components/controld_manager /workspaces/core/config/custom_components/controld_manager",
        "runOptions": {
          "runOn": "folderOpen"
        }
      },
      {
        "label": "Ruff",
        "type": "shell",
        "command": "python -m ruff check ."
      },
      {
        "label": "MyPy",
        "type": "shell",
        "command": "python -m mypy custom_components/controld_manager"
      },
      {
        "label": "Pytest",
        "type": "shell",
        "command": "python -m pytest tests/ -v"
      }
    ]
  }
}